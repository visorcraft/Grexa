# Builds the Grexa GUI + CLI from the local source tree. Run from this
# directory with:
#
#     makepkg -si

pkgname=grexa
pkgver=1.4.0
pkgrel=1
pkgdesc="Fast Linux file content search with tabs, replace, and AI assistance"
arch=('x86_64')
url="https://github.com/visorcraft/Grexa"
license=('GPL-3.0-only')
depends=(
    'qt6-base'
    'qt6-declarative'
    'kirigami'
    'hicolor-icon-theme'
    'poppler'
)
makedepends=(
    'cargo'
    'rust'
    'pkgconf'
    'qt6-tools'
    'clang'
    'ninja'
)
optdepends=(
    'podman: container search via rootless Podman'
    'docker: container search via Docker'
    'kwalletmanager: API key storage (KDE)'
    'gnome-keyring: API key storage (non-KDE)'
)
provides=('grexa-cli')
conflicts=('grexa-bin' 'grexa-git')
options=('!lto')
source=()
sha256sums=()

_srcdir="${startdir}/../.."

build() {
    cd "${_srcdir}"
    cargo build --workspace --release --locked
}

check() {
    cd "${_srcdir}"
    cargo test --workspace --release --locked --no-run
}

package() {
    cd "${_srcdir}"

    install -Dm755 "target/release/grexa" "${pkgdir}/usr/bin/grexa"
    install -Dm755 "target/release/grexa-cli" "${pkgdir}/usr/bin/grexa-cli"

    install -Dm644 packaging/com.visorcraft.Grexa.desktop \
        "${pkgdir}/usr/share/applications/com.visorcraft.Grexa.desktop"
    install -Dm644 packaging/com.visorcraft.Grexa.metainfo.xml \
        "${pkgdir}/usr/share/metainfo/com.visorcraft.Grexa.metainfo.xml"
    install -Dm644 packaging/icons/scalable/com.visorcraft.Grexa.svg \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/com.visorcraft.Grexa.svg"
    for size in 16 24 32 48 64 96 128 192 256 512; do
        install -Dm644 "packaging/icons/${size}x${size}/apps/com.visorcraft.Grexa.png" \
            "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/com.visorcraft.Grexa.png"
    done

    "${pkgdir}/usr/bin/grexa-cli" manpage \
        | install -Dm644 /dev/stdin "${pkgdir}/usr/share/man/man1/grexa-cli.1"

    "${pkgdir}/usr/bin/grexa-cli" completions bash \
        | install -Dm644 /dev/stdin "${pkgdir}/usr/share/bash-completion/completions/grexa-cli"
    "${pkgdir}/usr/bin/grexa-cli" completions fish \
        | install -Dm644 /dev/stdin "${pkgdir}/usr/share/fish/vendor_completions.d/grexa-cli.fish"
    "${pkgdir}/usr/bin/grexa-cli" completions zsh \
        | install -Dm644 /dev/stdin "${pkgdir}/usr/share/zsh/site-functions/_grexa-cli"

    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
